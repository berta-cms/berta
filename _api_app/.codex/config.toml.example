[mcp_servers.laravel-boost]
command = "php"
args = ["artisan", "boost:mcp"]
cwd = "/path/to/berta/_api_app"

[mcp_servers.herd]
command = "php"
args = ["/Applications/Herd.app/Contents/Resources/herd-mcp.phar"]
cwd = "/path/to/berta/_api_app"

[mcp_servers.herd.env]
SITE_PATH = "/path/to/berta/_api_app"
